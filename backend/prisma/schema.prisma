// creates a prisma object used in routes
// allows prisma.transaction.create()
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String
  name           String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]

  @@index([organizationId])
  @@index([email])
}

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  date           DateTime
  description    String
  amount         Decimal  @db.Decimal(10, 2)
  balanceAfter   Decimal? @db.Decimal(10, 2)
  category       String?
  confidence     Float    @default(1.0)
  rawText        String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // INDEXES: Critical for the "Performance" and "Isolation" requirement
  @@index([userId])
  @@index([organizationId])
  @@index([date])
  @@index([createdAt]) // Added for cursor-pagination performance
  @@index([organizationId, date]) // Composite index for dashboard queries
}